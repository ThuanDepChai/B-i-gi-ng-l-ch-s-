let qCur=0,qScoreVal=0,answered=false;
function startQuiz(){
  qCur=0;qScoreVal=0;answered=false;
  document.getElementById('quizArea').style.display='block';
  document.getElementById('quizEnd').style.display='none';
  loadQ();
}
function loadQ(){
  if(qCur>=QUESTIONS.length){endQuiz();return;}
  answered=false;
  const q=QUESTIONS[qCur];
  document.getElementById('qProg').style.width=((qCur+1)/QUESTIONS.length*100)+'%';
  document.getElementById('qLabel').textContent=`Câu ${qCur+1} / ${QUESTIONS.length}`;
  document.getElementById('qScore').textContent=qScoreVal;
  document.getElementById('qNum').textContent=`CÂU HỎI ${qCur+1}`;
  document.getElementById('qText').textContent=q.q;
  document.getElementById('qExp').className='quiz-explain';
  document.getElementById('qExp').textContent='';
  document.getElementById('qNextBtn').style.display='none';
  document.getElementById('qResultBadge').textContent='';
  const oc=document.getElementById('qOpts');
  oc.innerHTML='';
  q.o.forEach((o,i)=>{
    const b=document.createElement('button');
    b.className='quiz-opt';
    b.textContent=String.fromCharCode(65+i)+'. '+o;
    b.onclick=()=>selectA(i,b);
    oc.appendChild(b);
  });
}
function selectA(i,btn){
  if(answered)return;
  answered=true;
  const q=QUESTIONS[qCur];
  document.querySelectorAll('.quiz-opt').forEach((b,idx)=>{
    b.disabled=true;
    if(idx===q.a)b.classList.add('correct');
  });
  const expEl=document.getElementById('qExp');
  expEl.textContent='💡 '+q.e;
  expEl.classList.add('show');
  const rb=document.getElementById('qResultBadge');
  if(i===q.a){qScoreVal++;btn.classList.add('correct');rb.textContent='✅ Đúng!';rb.style.color='#22c55e';}
  else{btn.classList.add('wrong');rb.textContent='❌ Chưa đúng';rb.style.color='#ef4444';}
  document.getElementById('qScore').textContent=qScoreVal;
  document.getElementById('qNextBtn').style.display='inline-block';
  qCur++;
}
function nextQ(){
  if(qCur>=QUESTIONS.length){endQuiz();}else{loadQ();}
}
function endQuiz(){
  document.getElementById('quizArea').style.display='none';
  document.getElementById('quizEnd').style.display='block';
  const pct=Math.round(qScoreVal/QUESTIONS.length*100);
  document.getElementById('finalScore').textContent=qScoreVal;
  document.getElementById('finalTot').textContent='/'+QUESTIONS.length;
  let msg,sub;
  if(pct>=90){msg='🌟 Xuất sắc!';sub='Bạn nắm vững kiến thức Văn minh Ai Cập. Hãy chuẩn bị Bài 5 nhé!';}
  else if(pct>=70){msg='👍 Khá tốt!';sub='Ôn lại phần bạn còn sai, tập trung vào niên đại và thành tựu khoa học.';}
  else if(pct>=50){msg='📚 Cần cố gắng thêm';sub='Xem lại phần Kiến thức và Ghi nhớ, rồi làm lại bài kiểm tra.';}
  else{msg='💪 Hãy ôn lại từ đầu';sub='Bắt đầu từ tab Kiến thức → Niên đại → Flashcard trước khi làm quiz.';}
  document.getElementById('scoreMsg').textContent=msg;
  document.getElementById('scoreSub').textContent=sub;
}

